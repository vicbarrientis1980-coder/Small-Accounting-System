# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DB=accounting_system

# Database URI
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:your-password@localhost/accounting_system

# Application Settings
DEBUG=True
TESTING=False
